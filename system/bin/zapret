#!/system/bin/sh

pidof "nfqws" > /dev/null && echo "zapret is running" || echo "zapret is not running"

if [ "$1" = "start" ]; then
    check_iptables_support() {
        if iptables -t mangle -A POSTROUTING -p tcp -m connbytes --connbytes-dir=original --connbytes-mode=packets --connbytes 1:12 -j ACCEPT 2>/dev/null; then
            iptables -t mangle -D POSTROUTING -p tcp -m connbytes --connbytes-dir=original --connbytes-mode=packets --connbytes 1:12 -j ACCEPT 2>/dev/null
            HAS_CONNBYTES=1
        else
            HAS_CONNBYTES=0
        fi
        if iptables -t mangle -A POSTROUTING -p tcp -m multiport --dports 80,443 -j ACCEPT 2>/dev/null; then
            iptables -t mangle -D POSTROUTING -p tcp -m multiport --dports 80,443 -j ACCEPT 2>/dev/null
            HAS_MULTIPORT=1
        else
            HAS_MULTIPORT=0
        fi
    }
    check_iptables_support

    echo "Starting zapret...";

    DESYNC_MARK=0x40000000
    args="--qnum=200 --uid=0:0 --dpi-desync-fwmark=$DESYNC_MARK"

    while IFS= read -r line; do
        line="${line//\{hosts\}//data/adb/zapret/autohosts.txt}"
        line="${line//\{ignore\}//data/adb/zapret/ignore.txt}"
        line="${line//\{ipset\}//data/adb/zapret/ipset.txt}"
        line="${line//\{whitelist\}//data/adb/zapret/whitelist.txt}"
        line="${line//\{youtube\}//etc/youtube.txt}"
        line="${line//\{quicgoogle\}//etc/quic_initial_www_google_com.bin}"
        line="${line//\{tlsgoogle\}//etc/tls_clienthello_www_google_com.bin}"
        line="$(echo "$line" | sed -E 's/--wf-(tcp|udp)=[^ ]+//g')"
        line="$(echo "$line" | sed -E 's/  +/ /g' | sed -E 's/^ //;s/ $//')"
        [ -n "$line" ] && args="$args $line"
    done < /data/adb/zapret/config.txt

    sysctl net.netfilter.nf_conntrack_tcp_be_liberal=1 > /dev/null;
    TCP_PORTS=$(echo "$args" | tr ' ' '\n' | grep '^--filter-tcp=' | sed 's/--filter-tcp=//')
    UDP_PORTS=$(echo "$args" | tr ' ' '\n' | grep '^--filter-udp=' | sed 's/--filter-udp=//')

    extra_flags=""
    if [ "$HAS_CONNBYTES" = "1" ]; then
        extra_flags="-m connbytes --connbytes-dir=original --connbytes-mode=packets --connbytes 1:12"
    fi
    if [ "$HAS_CONNBYTES" = "1" ]; then
        extra_flags="$extra_flags -m mark ! --mark $DESYNC_MARK/$DESYNC_MARK"
    fi

    add_ipt_rule() {
        local proto=$1
        local port=$2
        iptables -t mangle -I POSTROUTING -p "$proto" --dport "$port" $extra_flags -j NFQUEUE --queue-num 200 --queue-bypass
        ip6tables -t mangle -I POSTROUTING -p "$proto" --dport "$port" $extra_flags -j NFQUEUE --queue-num 200 --queue-bypass
    }

    add_ipt_rules_multiport() {
        local proto=$1
        local ports=$2
        iptables -t mangle -I POSTROUTING -p "$proto" -m multiport --dports "$ports" $extra_flags -j NFQUEUE --queue-num 200 --queue-bypass
        ip6tables -t mangle -I POSTROUTING -p "$proto" -m multiport --dports "$ports" $extra_flags -j NFQUEUE --queue-num 200 --queue-bypass
    }

    add_ipt_for_proto() {
        local proto=$1
        local raw_ports=$2
        if [ -z "$raw_ports" ]; then
            return
        fi
        if [ "$HAS_MULTIPORT" = "1" ]; then
            local merged=$(echo "$raw_ports" | paste -sd, | sed 's/-/:/g')
            add_ipt_rules_multiport "$proto" "$merged"
        else
            echo "$raw_ports" | tr ',' '\n' | while read -r p; do
                local port=$(echo "$p" | sed 's/-/:/g')
                add_ipt_rule "$proto" "$port"
            done
        fi
    }

    add_ipt_for_proto "tcp" "$TCP_PORTS"
    add_ipt_for_proto "udp" "$UDP_PORTS"

    nfqws $args > /dev/null &
    echo "zapret service started!"; exit 0; fi

if [ "$1" = "stop" ]; then
    iptables -t mangle -F POSTROUTING;
    ip6tables -t mangle -F POSTROUTING;
    pid=$(pidof nfqws)
    if [ -n "$pid" ]; then
        kill "$pid";
    fi
    echo "zapret service stopped!"; exit 0;
fi;

if [ "$1" = "autostart-on" ]; then
    touch /data/adb/zapret/autostart;
    echo "Autostart enabled"
fi;

if [ "$1" = "autostart-off" ]; then
    rm /data/adb/zapret/autostart;
    echo "Autostart disabled"
fi;

if [ -z "$1" ]; then
    echo "zapret for Magisk. Source: https://github.com/bol-van/zapret. Build: https://github.com/ImMALWARE/zapret-magisk. Usage: zapret start, zapret stop, zapret autostart-on, zapret autostart-off.";
fi;